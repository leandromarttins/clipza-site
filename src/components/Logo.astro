---
interface Props {
  variant?: 'dark' | 'light'
  class?: string
}

// variant="dark"  → logo branco, para fundos escuros (site dark, navbar transparente)
// variant="light" → logo preto,  para fundos claros
const { variant = 'dark', class: className = 'h-10 w-auto' } = Astro.props
const src = variant === 'dark' ? '/logo-dark.png' : '/logo-light.png'
---

<img src={src} alt="CLIPZA" class={className} draggable="false" />
